# Stocktre Expo App Environment Configuration
# Copy this file to .env and update values as needed

# ===========================================
# LOCAL DEVELOPMENT
# ===========================================
# Find your IP: Run `ipconfig getifaddr en0` in terminal (Mac)
# Or use `hostname -I` on Linux

API_URL=http://YOUR_LOCAL_IP:3001
WS_URL=http://YOUR_LOCAL_IP:3001

# ===========================================
# PRODUCTION
# ===========================================
# API_URL=https://your-production-api.com
# WS_URL=https://your-production-api.com

# ===========================================
# APP INFO
# ===========================================
APP_NAME=Stocktre
APP_VERSION=1.0.0
