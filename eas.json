{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EAS_NO_VCS": "1",
        "API_URL": "https://api.stocktre.com",
        "WS_URL": "https://api.stocktre.com",
        "CHART_LIB_URL": "https://stocktre.com",
        "APP_NAME": "Stocktre",
        "APP_VERSION": "1.0.0"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "API_URL": "https://api.stocktre.com",
        "WS_URL": "https://api.stocktre.com",
        "CHART_LIB_URL": "https://stocktre.com",
        "APP_NAME": "Stocktre",
        "APP_VERSION": "1.0.0"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
